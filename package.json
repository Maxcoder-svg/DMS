{
  "name": "dms-discipline-management-system",
  "version": "1.0.0",
  "description": "A discipline management system for tracking progress and managing tasks with Twilio SMS and Firebase push notifications",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "nodemon server/index.js",
    "build": "npm run build:client",
    "build:client": "cd client && npm run build",
    "install:all": "npm install && cd client && npm install",
    "dev:server": "nodemon server/index.js",
    "dev:client": "cd client && npm start"
  },
  "keywords": ["task-management", "discipline", "notifications", "twilio", "firebase"],
  "author": "DMS Team",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "sqlite3": "^5.1.6",
    "twilio": "^4.19.0",
    "firebase-admin": "^11.11.1",
    "node-cron": "^3.0.2",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  }
}